generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER  @map("user")
  ADMIN @map("admin")
}

enum ProjectStatus {
  UPLOADED   @map("uploaded")
  PROCESSING @map("processing")
  READY      @map("ready")
  FAILED     @map("failed")
}

enum ProcessingJobType {
  INGEST_VIDEO  @map("ingest_video")
  EXTRACT_AUDIO @map("extract_audio")
  TRANSCODE     @map("transcode")
  TRANSCRIBE    @map("transcribe")
  DETECT_CLIPS  @map("detect_clips")
  RENDER_CLIPS  @map("render_clips")
}

enum ProcessingJobStatus {
  QUEUED    @map("queued")
  RUNNING   @map("running")
  SUCCEEDED @map("succeeded")
  FAILED    @map("failed")
}

enum ClipStatus {
  QUEUED     @map("queued")
  RENDERING  @map("rendering")
  READY      @map("ready")
  FAILED     @map("failed")
}

enum ClipAssetType {
  VIDEO      @map("video")
  THUMBNAIL  @map("thumbnail")
  SUBTITLE   @map("subtitle")
  TRANSCRIPT @map("transcript")
  AUDIO      @map("audio")
}

enum Plan {
  FREE    @map("free")
  CREATOR @map("creator")
  PRO     @map("pro")
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole      @default(USER)
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  subscription  Subscription?
  usageLedger   UsageLedger[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id                 String              @id @default(cuid())
  userId             String
  title              String
  status             ProjectStatus       @default(UPLOADED)
  sourceVideo        SourceVideo?
  processingJobs     ProcessingJob[]
  transcriptSegments TranscriptSegment[]
  clips              Clip[]
  usageLedger        UsageLedger[]
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([userId, createdAt])
  @@index([status])
}

model SourceVideo {
  id              String   @id @default(cuid())
  projectId       String   @unique
  originalFileUrl String?
  storageKey      String
  durationSeconds Int?
  width           Int?
  height          Int?
  fps             Float?
  sizeBytes       BigInt?
  codec           String?
  metadataJson    Json?
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProcessingJob {
  id        String              @id @default(cuid())
  projectId String
  type      ProcessingJobType
  status    ProcessingJobStatus @default(QUEUED)
  progress  Int                 @default(0)
  logs      String[]            @default([])
  error     String?
  attempts  Int                 @default(0)
  project   Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([projectId, createdAt])
  @@index([status, type])
}

model TranscriptSegment {
  id         String  @id @default(cuid())
  projectId  String
  startMs    Int
  endMs      Int
  text       String  @db.Text
  confidence Float?
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, startMs])
}

model Clip {
  id               String      @id @default(cuid())
  projectId        String
  title            String
  hook             String
  description      String?
  startMs          Int
  endMs            Int
  durationMs       Int
  viralScore       Int
  reason           String      @db.Text
  status           ClipStatus  @default(QUEUED)
  outputUrl        String?
  thumbnailUrl     String?
  captionStyleJson Json?
  cropJson         Json?
  assets           ClipAsset[]
  project          Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([projectId, viralScore])
  @@index([status])
}

model ClipAsset {
  id           String        @id @default(cuid())
  clipId       String
  type         ClipAssetType
  url          String?
  storageKey   String
  metadataJson Json?
  clip         Clip          @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@index([clipId, type])
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  plan                 Plan     @default(FREE)
  status               String   @default("active")
  currentPeriodEnd     DateTime?
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model UsageLedger {
  id        String   @id @default(cuid())
  userId    String
  projectId String?
  type      String
  amount    Int
  unit      String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([projectId])
}
