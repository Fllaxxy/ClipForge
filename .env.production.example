# ClipForge production environment template.
# Do not commit real secrets. In Render, most of these are configured in the Blueprint UI.

# Render Postgres. The Blueprint fills this from the clipforge-postgres internal connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/clipforge"

# Render Key Value/Redis. The Blueprint fills this from the clipforge-redis internal connection string.
REDIS_URL="redis://HOST:6379"

# Public web URL. On Render, scripts/render-start.sh derives these from RENDER_EXTERNAL_URL if omitted.
NEXTAUTH_URL="https://clipforge-web.onrender.com"
NEXTAUTH_SECRET="generate-a-long-random-secret"
NEXT_PUBLIC_APP_URL="https://clipforge-web.onrender.com"

# Cloudflare R2 S3-compatible storage.
# S3_ENDPOINT must be the S3 API endpoint from the R2 dashboard.
S3_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
# For first private signed-URL deploys, set S3_PUBLIC_ENDPOINT to the same value as S3_ENDPOINT.
# Use a public R2 custom domain or Worker URL only if it can serve the generated asset URLs.
S3_PUBLIC_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_BUCKET="clipforge"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"

# First deploy defaults: no paid AI or transcription provider required.
TRANSCRIPTION_PROVIDER="mock"
AI_PROVIDER="mock"

# Optional OpenAI-compatible clip detection/transcription providers.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
AI_API_KEY=""
AI_BASE_URL=""
AI_MODEL="gpt-4o-mini"
TRANSCRIPTION_API_KEY=""
TRANSCRIPTION_BASE_URL=""
TRANSCRIPTION_MODEL="whisper-1"

# Optional local Whisper settings for a self-hosted worker.
LOCAL_WHISPER_COMMAND="whisper"
LOCAL_WHISPER_ARGS="--output_format json --word_timestamps False"

# Optional Stripe. Leave blank to keep billing checkout/portal disabled.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CREATOR_PRICE_ID=""
STRIPE_PRO_PRICE_ID=""

# Runtime tuning.
CLIPFORGE_QUEUE_NAME="clipforge"
CLIPFORGE_TMP_DIR="/tmp/clipforge"
MAX_UPLOAD_BYTES="1073741824"
WORKER_CONCURRENCY="2"
FFMPEG_PATH="ffmpeg"
FFPROBE_PATH="ffprobe"
FFMPEG_PRESET="veryfast"
PRISMA_LOG_QUERIES="false"
RUN_SEED_ON_START="false"
